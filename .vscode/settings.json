{
  "stylua.targetReleaseVersion": "latest",
  "editor.formatOnSave": true,
  "files.eol": "\n",
  "files.exclude": {
    "**/LICENSE": true,
    "**/*-lock.*": true,
    "**/*.lock.*": true,
    "**/*.lock": true,
    "**/*_packages": true,
    "**/.pesde": true,
    "**/.luaurc": true,
    ".github": true,
    ".gitignore": true,
    ".gitattributes": true,
    ".claude": true,
    ".vscode": true,
    ".env": true,
    ".zed": true,
    "sourcemap.json": true,
    "stylua.toml": true,
    "pesde.toml": true,
    "mise.toml": true,
  },
  "files.readonlyInclude": {
    "**/LICENSE": true,
    "**/*-lock.*": true,
    "**/*.lock.*": true,
    "**/*.lock": true,
    "**/*_packages/**": true,
    "**/.pesde/**": true,
    "sourcemap.json": true
  },
  "luau-lsp.platform.type": "roblox",
  "luau-lsp.fflags.enableNewSolver": false,
  "luau-lsp.bytecode.vectorCtor": "new",
  "luau-lsp.bytecode.vectorLib": "Vector3",
  "luau-lsp.bytecode.vectorType": "Vector3",
  "luau-lsp.completion.imports.requireStyle": "alwaysRelative",
  "luau-lsp.completion.imports.stringRequires.enabled": true,
  "luau-lsp.completion.imports.ignoreGlobs": [
    "**/.pesde/**"
  ],
  "luau-lsp.ignoreGlobs": [
    "**/*_packages/**",
    "**/.pesde/**",
    "**/dist/**",
    "**/*.d.luau",
  ],
  "luau-lsp.types.robloxSecurityLevel": "LocalUserSecurity",
  "luau-lsp.types.definitionFiles": {
    "vector": "https://gist.githubusercontent.com/ernisto/3b0e3513700e20ccf8011efc77de234e/raw/3b140bcb8d6d7953d628bb3f3b6cf49d9784fbaf/vector.d.luau"
  },
}