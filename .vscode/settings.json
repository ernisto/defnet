    "**/*.lock.*": true,
    "**/*.lock": true,
    ".github": true,
    ".gitignore": true,
    ".gitattributes": true,
    ".luaurc": true,
    ".claude": true,
    ".vscode": true,
    ".env": true,
    ".zed": true,
    "sourcemap.json": true,
    "stylua.toml": true,
    "rokit.toml": true,
    "wally.toml": true
  },
  "files.readonlyInclude": {
    "**/LICENSE": true,
    "**/*-lock.*": true,
    "**/*.lock.*": true,
    "**/*.lock": true,
    "sourcemap.json": true
  },
